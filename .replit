modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Monaimetrics CLI"

[[workflows.workflow]]
name = "Monaimetrics CLI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m monaimetrics.cli"

[workflows.workflow.metadata]
outputType = "console"
